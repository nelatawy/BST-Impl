<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>


<AnchorPane prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #fdf6e3;"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Visualization.visController">

  <Pane fx:id="viewport"
        layoutX="12.0" layoutY="58.0"
        prefWidth="1076.0" prefHeight="630.0" />

  <Button AnchorPane.topAnchor="12.0"
          AnchorPane.leftAnchor="12.0"
          onAction="#insertInTree"
          mnemonicParsing="false"
          prefHeight="34.0" prefWidth="180.0"
          text="Insert" />

  <Button AnchorPane.topAnchor="12.0"
          AnchorPane.rightAnchor="12.0"
          onAction="#deleteFromTree"
          mnemonicParsing="false"
          prefHeight="34.0" prefWidth="180.0"
          text="Delete" />

  <TextField fx:id="value"
             AnchorPane.topAnchor="13.0"
             AnchorPane.leftAnchor="204.0"
             AnchorPane.rightAnchor="204.0"
             prefHeight="32.0" />

</AnchorPane>
